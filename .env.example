HOST=127.0.0.1
PORT=4180

ADMIN_USERNAME=OpenFrame
ADMIN_PASSWORD=Studio

# Create a self-built app in Lark Open Platform, grant Calendar permissions,
# then add the app to the target Lark tenant.
LARK_APP_ID=cli_xxxxxxxxxxxxxxxx
LARK_APP_SECRET=your_lark_app_secret

# Use "primary" for a primary calendar when the token has access, or a specific
# shared calendar ID such as xxx@group.calendar.larksuite.com.
LARK_CALENDAR_ID=primary

# Optional: set this to admin@openframe.studio's actual Lark calendar ID so
# external invitations are organized/sent by that admin calendar.
LARK_ORGANIZER_CALENDAR_ID=
LARK_SENDER_EMAIL=admin@openframe.studio
LARK_SENDER_NAME=admin@openframe.studio

LARK_TIMEZONE=Australia/Sydney
LARK_API_BASE=https://open.larksuite.com/open-apis

# Invoice email sender. Defaults are for Lark Mail.
INVOICE_EMAIL_HOST=smtp.larksuite.com
INVOICE_EMAIL_PORT=465
INVOICE_EMAIL_SECURE=true
INVOICE_EMAIL_USER=admin@openframe.studio
INVOICE_EMAIL_PASSWORD=your_lark_email_password_or_app_password
# The app also accepts INVOICE_MAIL_PASSWORD if that name was already saved.
INVOICE_EMAIL_FROM=OpenFrame Studio <admin@openframe.studio>
INVOICE_EMAIL_REPLY_TO=admin@openframe.studio
INVOICE_EMAIL_BCC=
INVOICE_EMAIL_TIMEOUT_MS=15000
